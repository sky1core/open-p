{
  "name": "open-p",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "openp": "./dist/src/cli.js"
  },
  "files": [
    "dist/src/",
    "scripts/install-claude-shim.mjs",
    "README.md"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "verify": "npm run typecheck && npm test",
    "prepare": "npm run build",
    "install:claude-shim": "node scripts/install-claude-shim.mjs",
    "smoke:live": "node scripts/live-smoke.mjs",
    "verify:claude-p-contract": "node scripts/verify-claude-p-contract.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "yaml": "^2.9.0"
  }
}
